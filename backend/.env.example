# ============ Server Configuration ============
PORT=5000
NODE_ENV=production
CORS_ORIGIN=https://your-frontend-domain.com,https://your-alternate-domain.com

# ============ Database Configuration ============
# Option 1: Use full connection string (recommended for production)
DB_URL=postgresql://username:password@host:port/database

# Option 2: Use individual components (fallback)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=celebrity_browser

# ============ Authentication ============
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# ============ Payment Processing (Stripe) ============
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key

# ============ File Upload Configuration ============
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# ============ Email Configuration (Optional) ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@celebritybrowser.com

# ============ Redis Configuration (Optional - for caching/sessions) ============
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ============ Logging ============
LOG_LEVEL=info

# ============ API Configuration ============
API_VERSION=v1
